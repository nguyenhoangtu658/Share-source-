local TweenService = game:GetService("TweenService")

local darkGreen = Color3.fromRGB(0, 120, 0)
local neonGreen = Color3.fromRGB(0, 255, 0)
local redColor = Color3.fromRGB(255, 0, 0)

local function RunIntro()
    local introGui = Instance.new("ScreenGui")
    local Blackout = Instance.new("Frame")
    local Title = Instance.new("TextLabel")
    local Subtitle = Instance.new("TextLabel")

    introGui.Name = "HackerIntro"
    introGui.Parent = game:GetService("CoreGui")
    introGui.IgnoreGuiInset = true

    Blackout.Size = UDim2.new(1,0,1,0)
    Blackout.BackgroundColor3 = Color3.new(0,0,0)
    Blackout.BorderSizePixel = 0
    Blackout.Parent = introGui

    Title.Size = UDim2.new(1,0,0.5,0)
    Title.Position = UDim2.new(0,0,0.25,0)
    Title.BackgroundTransparency = 1
    Title.Text = "ACCESS GRANTED"
    Title.TextColor3 = darkGreen
    Title.Font = Enum.Font.Code
    Title.TextSize = 40
    Title.TextStrokeTransparency = 0
    Title.TextStrokeColor3 = neonGreen
    Title.Parent = Blackout

    Subtitle.Size = UDim2.new(1,0,0.1,0)
    Subtitle.Position = UDim2.new(0,0,0.6,0)
    Subtitle.BackgroundTransparency = 1
    Subtitle.Text = "Loading..."
    Subtitle.TextColor3 = darkGreen
    Subtitle.Font = Enum.Font.Code
    Subtitle.TextSize = 18
    Subtitle.TextStrokeTransparency = 0.5
    Subtitle.TextStrokeColor3 = neonGreen
    Subtitle.Parent = Blackout

    task.spawn(function()

        local running = true

        for i = 1,49 do
            task.spawn(function()
                while running and Blackout.Parent do
                    local m = Instance.new("TextLabel")

                    local normalErrors = {
                        "Error! 401",
                        "Error! 402",
                        "Error! 403",
                        "Error! 404"
                    }

                    local criticalErrors = {
                        "SYSTEM FAILURE!",
                        "CRITICAL ERROR!"
                    }

                    if math.random(1,3) == 1 then
                        m.Text = criticalErrors[math.random(1,#criticalErrors)]
                        m.TextColor3 = redColor
                        m.TextStrokeColor3 = redColor
                        m.TextSize = math.random(10,20)
                    else
                        m.Text = normalErrors[math.random(1,#normalErrors)]
                        m.TextColor3 = neonGreen
                        m.TextStrokeColor3 = neonGreen
                        m.TextSize = math.random(14,26)
                    end

                    m.Position = UDim2.new(math.random(),0,math.random(),0)
                    m.BackgroundTransparency = 1
                    m.TextStrokeTransparency = 0.3
                    m.Font = Enum.Font.Code
                    m.TextTransparency = 1
                    m.Parent = Blackout

                    local duration = math.random(5,15)/10

                    TweenService:Create(m, TweenInfo.new(duration/2), {TextTransparency = 0}):Play()
                    task.wait(duration)
                    TweenService:Create(m, TweenInfo.new(duration/2), {TextTransparency = 1}):Play()

                    game:GetService("Debris"):AddItem(m, duration)
                    task.wait(math.random(3,8)/10)
                end
            end)
        end

        task.wait(4)

        running = false

        Subtitle.Text = "ACCESS SUCCESSFUL"
        Subtitle.TextColor3 = neonGreen

        for i = 1,25 do
            local m = Instance.new("TextLabel")

            local successText = {
                "ACCESS GRANTED",
                "INFILTRATION SUCCESS"
            }

            m.Text = successText[math.random(1,#successText)]
            m.TextColor3 = neonGreen
            m.TextStrokeColor3 = neonGreen
            m.TextSize = math.random(10,20)

            m.Position = UDim2.new(math.random(),0,math.random(),0)
            m.BackgroundTransparency = 1
            m.TextStrokeTransparency = 0.3
            m.Font = Enum.Font.Code
            m.TextTransparency = 1
            m.Parent = Blackout

            TweenService:Create(m, TweenInfo.new(0.5), {TextTransparency = 0}):Play()
            game:GetService("Debris"):AddItem(m, 1)
        end

        task.wait(1)

        local fade = TweenInfo.new(1, Enum.EasingStyle.Linear)
        TweenService:Create(Blackout, fade, {BackgroundTransparency = 1}):Play()
        TweenService:Create(Title, fade, {TextTransparency = 1}):Play()
        TweenService:Create(Subtitle, fade, {TextTransparency = 1}):Play()

        task.wait(1)
        introGui:Destroy()
    end)
end

RunIntro()
