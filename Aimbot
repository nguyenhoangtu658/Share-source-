local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local MAX_DISTANCE = 1200
local PREDICTION = 0.12
local TEAM_CHECK = true
local Z_LOCK_TIME = 0.15
local Z_DISABLE_SILENT_TIME = 0.2

local TargetPosition = nil
local CurrentTool = nil
local SilentAimEnabled = true
local AimMasterEnabled = true
local ZUsing = false

local function getHRP(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function isAlive(char)
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function isEnemy(plr)
    if plr == LocalPlayer then return false end
    if not TEAM_CHECK then return true end
    if not plr.Team or not LocalPlayer.Team then return true end
    return plr.Team ~= LocalPlayer.Team
end

local function getPredictedPos(hrp)
    return hrp.Position + (hrp.Velocity * PREDICTION)
end

local function getClosestEnemy()
    local char = LocalPlayer.Character
    local hrp = getHRP(char)
    if not hrp then return nil end

    local closest, dist = nil, math.huge

    for _, plr in ipairs(Players:GetPlayers()) do
        if isEnemy(plr) and plr.Character and isAlive(plr.Character) then
            local ehrp = getHRP(plr.Character)
            if ehrp then
                local d = (ehrp.Position - hrp.Position).Magnitude
                if d < dist and d <= MAX_DISTANCE then
                    dist = d
                    closest = ehrp
                end
            end
        end
    end

    return closest
end

RunService.RenderStepped:Connect(function()
    if not AimMasterEnabled or not SilentAimEnabled then
        TargetPosition = nil
        return
    end

    local targetHRP = getClosestEnemy()
    if targetHRP then
        TargetPosition = getPredictedPos(targetHRP)
    else
        TargetPosition = nil
    end
end)

local function lockCameraTo(pos, time)
    if not pos or not AimMasterEnabled then return end

    local oldType = Camera.CameraType
    Camera.CameraType = Enum.CameraType.Scriptable
    Camera.CFrame = CFrame.new(Camera.CFrame.Position, pos)

    task.delay(time, function()
        Camera.CameraType = oldType
    end)
end

local function hookCharacter(char)
    char.ChildAdded:Connect(function(obj)
        if obj:IsA("Tool") then
            CurrentTool = obj
        end
    end)

    char.ChildRemoved:Connect(function(obj)
        if obj == CurrentTool then
            CurrentTool = nil
        end
    end)
end

if LocalPlayer.Character then
    hookCharacter(LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(hookCharacter)

local mt = getrawmetatable(game)
setreadonly(mt, false)

local oldNamecall = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    if not AimMasterEnabled then
        return oldNamecall(self, ...)
    end

    local method = getnamecallmethod()
    local args = {...}

    if method == "FireServer" or method == "InvokeServer" then
        local key = args[1]

        if typeof(key) == "string"
            and key:upper() == "Z"
            and CurrentTool
            and CurrentTool.Name == "Godhuman"
            and not ZUsing
        then
            ZUsing = true
            SilentAimEnabled = false

            if TargetPosition then
                lockCameraTo(TargetPosition, Z_LOCK_TIME)
            end

            task.delay(Z_DISABLE_SILENT_TIME, function()
                SilentAimEnabled = true
                ZUsing = false
            end)
        end

        if SilentAimEnabled and TargetPosition then
            for i, v in ipairs(args) do
                if typeof(v) == "Vector3" then
                    args[i] = TargetPosition
                    return oldNamecall(self, unpack(args))
                end
            end
        end
    end

    return oldNamecall(self, ...)
end)

setreadonly(mt, true)
